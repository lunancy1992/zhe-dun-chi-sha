/* 全局样式 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 主题色 */
.primary-color {
  color: #FF6B35;
}

.primary-bg {
  background-color: #FF6B35;
}

/* 通用样式 */
.container {
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.tag-spicy {
  background-color: #FFE4E1;
  color: #FF4500;
}

.tag-sour {
  background-color: #FFF8DC;
  color: #DAA520;
}

.tag-sweet {
  background-color: #FFF0F5;
  color: #FF69B4;
}

/* 按钮样式 */
.btn-primary {
  background-color: #FF6B35;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-primary:active {
  background-color: #E55A2B;
}
