/* pages/index/index.wxss */

.container {
  display: flex;
  height: 100vh;
  background-color: #F5F5F5;
}

/* 左侧分类栏 */
.sidebar {
  width: 180rpx;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  border-right: 1rpx solid #eee;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 10rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #FFF5F0;
  border-left-color: #FF6B35;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 26rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 右侧内容区 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.dish-count {
  font-size: 26rpx;
  color: #999;
}

.filter-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

.filter-icon {
  margin-right: 8rpx;
}

/* 筛选面板 */
.filter-panel {
  background-color: #fff;
  padding: 0 24rpx;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s, padding 0.3s;
}

.filter-panel.show {
  max-height: 200rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-tags {
  display: flex;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
}

.filter-tag.selected {
  background-color: #FFF5F0;
  color: #FF6B35;
  border-color: #FF6B35;
}

.filter-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
}

/* 菜品列表 */
.dish-list {
  flex: 1;
  padding: 20rpx;
}

.dish-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.dish-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dish-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.tag-spicy {
  background-color: #FFE4E1;
  color: #FF4500;
}

.tag-sour {
  background-color: #FFF8DC;
  color: #DAA520;
}

.tag-sweet {
  background-color: #FFF0F5;
  color: #FF69B4;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
