<!--pages/index/index.wxml-->
<view class="page">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索菜名..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
      <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{isSearching}}" class="search-results">
    <view class="search-result-header">
      <text class="dish-count">找到 {{searchResults.length}} 道菜</text>
    </view>
    <scroll-view scroll-y class="search-result-list">
      <view
        wx:for="{{searchResults}}"
        wx:key="id"
        class="dish-card"
        data-dish="{{item}}"
        data-category="{{item.categoryKey}}"
        bindtap="goToSearchDetail"
      >
        <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <view class="dish-meta">
            <text class="dish-category-tag">{{item.categoryName}}</text>
            <view class="dish-tags" wx:if="{{item.tags && item.tags.length > 0}}">
              <text
                wx:for="{{item.tags}}"
                wx:for-item="tag"
                wx:key="*this"
                class="dish-tag tag-{{tag === '偏辣' ? 'spicy' : tag === '偏酸' ? 'sour' : 'sweet'}}"
              >
                {{tag}}
              </text>
            </view>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view wx:if="{{searchResults.length === 0}}" class="empty-state">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">没有找到相关菜品</text>
      </view>
    </scroll-view>
  </view>

  <!-- 正常浏览内容 -->
  <view class="container" wx:else>
  <!-- 左侧分类栏 -->
  <view class="sidebar">
    <view
      wx:for="{{mainCategories}}"
      wx:key="key"
      class="category-item {{currentMainCategory === item.key ? 'active' : ''}}"
      data-category="{{item.key}}"
      bindtap="switchMainCategory"
    >
      <text class="category-icon">{{item.icon}}</text>
      <text class="category-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 右侧内容区 -->
  <view class="main-content">
    <!-- 菜系切换（仅热菜显示） -->
    <view class="cuisine-bar" wx:if="{{currentMainCategory === 'hot' && cuisineCategories.length > 0}}">
      <scroll-view scroll-x class="cuisine-scroll">
        <view
          class="cuisine-item {{currentCuisine === '' ? 'active' : ''}}"
          data-cuisine=""
          bindtap="switchCuisine"
        >
          全部
        </view>
        <view
          wx:for="{{cuisineCategories}}"
          wx:key="id"
          class="cuisine-item {{currentCuisine === item.id ? 'active' : ''}}"
          data-cuisine="{{item.id}}"
          bindtap="switchCuisine"
        >
          {{item.name}}
        </view>
      </scroll-view>
    </view>

    <!-- 顶部筛选栏 -->
    <view class="filter-bar">
      <view class="filter-left">
        <text class="dish-count">共 {{dishes.length}} 道菜</text>
      </view>
      <view class="filter-btn" bindtap="toggleFilter">
        <text class="filter-icon">🔽</text>
        <text>筛选</text>
      </view>
    </view>

    <!-- 筛选面板 -->
    <view class="filter-panel {{showFilter ? 'show' : ''}}">
      <view class="filter-tags">
        <view
          wx:for="{{filterTags}}"
          wx:key="key"
          class="filter-tag {{item.selected ? 'selected' : ''}}"
          data-tag="{{item.key}}"
          bindtap="selectTag"
        >
          {{item.name}}
        </view>
      </view>
      <view class="filter-actions">
        <view class="clear-btn" bindtap="clearFilter">清除</view>
      </view>
    </view>

    <!-- 菜品列表 -->
    <scroll-view scroll-y class="dish-list">
      <view
        wx:for="{{dishes}}"
        wx:key="id"
        class="dish-card"
        data-dish="{{item}}"
        bindtap="goToDetail"
      >
        <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <view class="dish-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="*this"
              class="dish-tag tag-{{tag === '偏辣' ? 'spicy' : tag === '偏酸' ? 'sour' : 'sweet'}}"
            >
              {{tag}}
            </text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{dishes.length === 0}}" class="empty-state">
        <text class="empty-icon">🍽️</text>
        <text class="empty-text">暂无符合条件的菜品</text>
      </view>
    </scroll-view>
  </view>
  </view>
</view>
